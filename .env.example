# Local persistence. Replace with a Postgres URL when deploying.
DATABASE_URL=sqlite:///./triage_mock.db
SEED_DEMO_DATA=true
APP_PUBLIC_URL=http://localhost:8200

# AI triage (OpenRouter). Leave the key blank to use the deterministic demo classifier.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5-mini
OPENROUTER_FALLBACK_MODELS=google/gemini-2.5-flash
OPENROUTER_TIMEOUT_SECONDS=25

# WhatsApp outbound notifications (Twilio Sandbox or approved sender).
# Leave blank to log deliveries as "simulated" without making network calls.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_CONSENT_CONTENT_SID=
TWILIO_FORM_CONTENT_SID=
